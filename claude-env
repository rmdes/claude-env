#!/usr/bin/env bash
set -euo pipefail

VERSION="0.3.0"

# --- Default variables ---
CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
BACKUP_DIR="${BACKUP_DIR:-$HOME/.claude-backups}"
DRY_RUN=false
VERBOSE=false
FORCE=false

# --- Color auto-detection ---
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    BLUE='\033[0;34m'
    YELLOW='\033[0;33m'
    RESET='\033[0m'
else
    RED=''
    GREEN=''
    BLUE=''
    YELLOW=''
    RESET=''
fi

# --- Logging helpers ---
die() {
    printf "${RED}error:${RESET} %s\n" "$*" >&2
    exit 1
}

info() {
    printf "${BLUE}info:${RESET} %s\n" "$*"
}

warn() {
    printf "${YELLOW}warn:${RESET} %s\n" "$*" >&2
}

debug() {
    if [[ "$VERBOSE" == true ]]; then
        printf "debug: %s\n" "$*" >&2
    fi
}

# =============================================================================
# EXCLUDE-BASED MODEL
#
# Instead of listing what to backup (fragile, misses new files), we backup
# EVERYTHING in $CLAUDE_DIR and only EXCLUDE specific items.
#
# Exclude sets control what is SKIPPED during backup+reset.
# By default: credentials and mcp are excluded (kept in place).
# Flags let you narrow or widen what gets excluded.
# =============================================================================

# Items to exclude from backup by default (kept in place, never touched)
EXCLUDE_CREDENTIALS=(
    ".credentials.json"
)

EXCLUDE_MCP=(
    "mcp-servers"
    ".mcp.json"
)

# Items preserved during 'clean' (session history, credentials, mcp)
PRESERVE_ON_CLEAN=(
    ".credentials.json"
    "mcp-servers"
    ".mcp.json"
    "projects"
    "sessions"
    "history.jsonl"
    "todos"
    "tasks"
    "plans"
)

# --- Exclude flag variables ---
INCLUDE_MCP=false
INCLUDE_CREDENTIALS=false
NO_RESET=false
EXCLUDE_EXTRA=()  # additional paths to exclude via --exclude

# --- Helper functions ---
_array_contains() {
    local needle="$1"; shift
    local item
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

# Build the final exclude list based on flags
_build_excludes() {
    local -a excludes=()

    # Always exclude the manifest itself (it's a backup artifact)
    excludes+=("manifest.json")

    # Credentials excluded unless --include-credentials
    if [[ "$INCLUDE_CREDENTIALS" != true ]]; then
        excludes+=("${EXCLUDE_CREDENTIALS[@]}")
    fi

    # MCP excluded unless --include-mcp
    if [[ "$INCLUDE_MCP" != true ]]; then
        excludes+=("${EXCLUDE_MCP[@]}")
    fi

    # Any --exclude paths
    if [[ ${#EXCLUDE_EXTRA[@]} -gt 0 ]]; then
        excludes+=("${EXCLUDE_EXTRA[@]}")
    fi

    printf '%s\n' "${excludes[@]}"
}

# List all top-level items in CLAUDE_DIR (files and directories)
_list_claude_items() {
    local item
    for item in "$CLAUDE_DIR"/* "$CLAUDE_DIR"/.*; do
        [[ -e "$item" ]] || continue
        local name
        name="$(basename "$item")"
        # Skip . and ..
        [[ "$name" == "." || "$name" == ".." ]] && continue
        printf '%s\n' "$name"
    done
}

# Check if an item matches any exclude pattern
_is_excluded() {
    local item="$1"
    shift
    local pattern
    for pattern in "$@"; do
        [[ "$item" == "$pattern" ]] && return 0
    done
    return 1
}

# --- Usage ---
usage() {
    cat <<'EOF'
claude-env — snapshot, restore, and manage Claude Code environments

USAGE
    claude-env <command> [options]

COMMANDS
    backup [name]       Create a named snapshot of the current Claude environment
    restore <name>      Restore a previously saved snapshot
    clean               Remove plugins, skills, agents, config — keep session history
    list                List all available snapshots
    diff <name>         Show differences between current environment and a snapshot
    help                Show this help message
    version             Show version

GLOBAL FLAGS
    --dir <path>        Set backup directory (default: ~/.claude-backups)
    --claude-dir <path> Set Claude config directory (default: ~/.claude)
    --dry-run           Show what would be done without making changes
    --verbose           Enable verbose/debug output
    --help, -h          Show this help message
    --version, -v       Show version

BACKUP FLAGS
    --no-reset          Skip resetting the environment after backup
    --include-mcp       Also backup MCP server configurations (excluded by default)
    --include-credentials
                        Also backup credential files (excluded by default)
    --exclude <path>    Exclude additional path(s) from backup (can be repeated)
    --force             Overwrite existing backup with same name

RESTORE FLAGS
    --force             Skip auto-backup of current state before restoring

CLEAN FLAGS
    --force             Skip confirmation prompt
    --also <path>       Also remove an item that would normally be preserved (repeatable)

EXAMPLES
    claude-env backup                      # Backup everything (auto-named)
    claude-env backup my-setup             # Backup with custom name
    claude-env backup --no-reset snapshot  # Backup without resetting
    claude-env backup --include-mcp full   # Include MCP configs too
    claude-env restore my-setup            # Restore a snapshot
    claude-env clean                       # Wipe tooling, keep history
    claude-env clean --force               # No confirmation
    claude-env list                        # List all snapshots
    claude-env diff my-setup               # Compare current env with snapshot
EOF
}

# --- JSON helper ---
_json_array() {
    local first=true
    printf '['
    for item in "$@"; do
        if [[ "$first" == true ]]; then
            first=false
        else
            printf ','
        fi
        printf '"%s"' "$item"
    done
    printf ']'
}

# --- backup command ---
cmd_backup() {
    local name=""

    # Parse backup-specific flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-reset)              NO_RESET=true; shift ;;
            --force)                 FORCE=true; shift ;;
            --include-mcp)           INCLUDE_MCP=true; shift ;;
            --include-credentials)   INCLUDE_CREDENTIALS=true; shift ;;
            --exclude)
                [[ $# -lt 2 ]] && die "--exclude requires a value"
                EXCLUDE_EXTRA+=("$2"); shift 2
                ;;
            -*)
                die "Unknown flag: $1"
                ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Determine backup name
    if [[ -z "$name" ]]; then
        name="$(date -u +%Y-%m-%dT%H-%M-%S)"
    fi

    # Validate
    [[ -d "$CLAUDE_DIR" ]] || die "Claude directory does not exist: $CLAUDE_DIR"

    local backup_path="$BACKUP_DIR/$name"
    if [[ -d "$backup_path" ]] && [[ "$FORCE" != true ]]; then
        die "Backup '$name' already exists at $backup_path. Use a different name or --force."
    fi

    # Build exclude list
    local -a excludes=()
    mapfile -t excludes < <(_build_excludes)

    debug "Excludes: ${excludes[*]}"

    # --- Copy phase: everything except excludes ---
    local -a copied_paths=()
    local -a excluded_paths=()

    while IFS= read -r item; do
        [[ -z "$item" ]] && continue

        if _is_excluded "$item" "${excludes[@]}"; then
            excluded_paths+=("$item")
            debug "Excluded: $item"
            continue
        fi

        local src="$CLAUDE_DIR/$item"
        local dest="$backup_path/$item"

        if [[ "$DRY_RUN" == true ]]; then
            info "[dry-run] Would copy: $item"
        else
            mkdir -p "$(dirname "$dest")"
            cp -a "$src" "$dest"
            debug "Copied: $item"
        fi
        copied_paths+=("$item")
    done < <(_list_claude_items)

    # --- Write manifest.json ---
    local created
    created="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local copied_json
    copied_json="$(_json_array "${copied_paths[@]}")"
    local excluded_json
    excluded_json="$(_json_array "${excluded_paths[@]}")"

    local manifest
    manifest=$(printf '{\n  "version": 2,\n  "created": "%s",\n  "name": "%s",\n  "backed_up": %s,\n  "excluded": %s,\n  "claude_dir": "%s"\n}' \
        "$created" "$name" "$copied_json" "$excluded_json" "$CLAUDE_DIR")

    if [[ "$DRY_RUN" == true ]]; then
        info "[dry-run] Would write manifest.json"
    else
        mkdir -p "$backup_path"
        printf '%s\n' "$manifest" > "$backup_path/manifest.json"
    fi

    # --- Reset phase: remove everything that was backed up ---
    local -a reset_paths=()

    if [[ "$NO_RESET" == true ]]; then
        debug "Skipping reset phase (--no-reset)"
    else
        for item in "${copied_paths[@]}"; do
            local target="$CLAUDE_DIR/$item"
            if [[ -e "$target" ]]; then
                if [[ "$DRY_RUN" == true ]]; then
                    info "[dry-run] Would remove: $item"
                else
                    rm -rf "$target"
                    debug "Removed: $item"
                fi
                reset_paths+=("$item")
            fi
        done
    fi

    # --- Summary ---
    if [[ "$DRY_RUN" == true ]]; then
        info "[dry-run] Backup '$name' would include ${#copied_paths[@]} item(s)"
        info "[dry-run] Excluded: ${excluded_paths[*]:-none}"
        if [[ "$NO_RESET" == true ]]; then
            info "[dry-run] Reset: skipped (--no-reset)"
        else
            info "[dry-run] Would reset ${#reset_paths[@]} item(s)"
        fi
    else
        local size
        size="$(du -sh "$backup_path" 2>/dev/null | cut -f1)"
        info "Backup created: $backup_path"
        info "Backed up ${#copied_paths[@]} item(s), excluded ${#excluded_paths[@]} item(s)"
        info "Excluded: ${excluded_paths[*]:-none}"
        if [[ "$NO_RESET" == true ]]; then
            info "Reset: skipped (--no-reset)"
        elif [[ ${#reset_paths[@]} -gt 0 ]]; then
            info "Reset ${#reset_paths[@]} item(s) from CLAUDE_DIR"
        else
            info "Nothing to reset"
        fi
        info "Total size: $size"
    fi
}

# --- restore command ---
cmd_restore() {
    local name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)
                FORCE=true; shift ;;
            -*)
                die "Unknown flag: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    [[ -n "$name" ]] || die "Backup name required. Usage: claude-env restore <name>"

    local backup_path="$BACKUP_DIR/$name"
    [[ -d "$backup_path" ]] || die "Backup '$name' not found at $backup_path"
    [[ -f "$backup_path/manifest.json" ]] || die "Invalid backup: manifest.json not found in $backup_path"

    # --- Dry-run mode ---
    if [[ "$DRY_RUN" == true ]]; then
        info "[dry-run] Would restore backup '$name' from $backup_path"
        local item
        for item in "$backup_path"/* "$backup_path"/.*; do
            [[ -e "$item" ]] || continue
            local bname
            bname="$(basename "$item")"
            [[ "$bname" == "." || "$bname" == ".." || "$bname" == "manifest.json" ]] && continue
            info "[dry-run] Would restore: $bname"
        done
        return 0
    fi

    # --- Auto-backup current state (unless --force) ---
    if [[ "$FORCE" != true ]]; then
        local auto_name="pre-restore-$(date -u +%Y-%m-%dT%H-%M-%S)"
        info "Auto-backing up current state as '$auto_name'..."

        # Reset flags for auto-backup
        INCLUDE_MCP=false
        INCLUDE_CREDENTIALS=false
        NO_RESET=true
        EXCLUDE_EXTRA=()
        FORCE=false

        cmd_backup "$auto_name" --no-reset
    fi

    # --- Restore phase: copy everything from backup except manifest ---
    local -a restored_paths=()

    local item
    for item in "$backup_path"/* "$backup_path"/.*; do
        [[ -e "$item" ]] || continue
        local bname
        bname="$(basename "$item")"
        [[ "$bname" == "." || "$bname" == ".." || "$bname" == "manifest.json" ]] && continue

        local dest="$CLAUDE_DIR/$bname"
        mkdir -p "$(dirname "$dest")"
        cp -a "$item" "$dest"
        debug "Restored: $bname"
        restored_paths+=("$bname")
    done

    # --- Summary ---
    info "Restored backup '$name' from $backup_path"
    info "Restored ${#restored_paths[@]} item(s)"
}

# --- clean command ---
cmd_clean() {
    local -a also_remove=()

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)  FORCE=true; shift ;;
            --also)
                [[ $# -lt 2 ]] && die "--also requires a value"
                also_remove+=("$2"); shift 2
                ;;
            -*)       die "Unknown flag: $1" ;;
            *)        die "Unexpected argument: $1" ;;
        esac
    done

    [[ -d "$CLAUDE_DIR" ]] || die "Claude directory does not exist: $CLAUDE_DIR"

    # Build the preserve list, minus any --also items
    local -a preserve=()
    local p
    for p in "${PRESERVE_ON_CLEAN[@]}"; do
        if ! _array_contains "$p" "${also_remove[@]+"${also_remove[@]}"}"; then
            preserve+=("$p")
        fi
    done

    # Determine what will be removed
    local -a to_remove=()
    while IFS= read -r item; do
        [[ -z "$item" ]] && continue
        if ! _array_contains "$item" "${preserve[@]}"; then
            to_remove+=("$item")
        fi
    done < <(_list_claude_items)

    if [[ ${#to_remove[@]} -eq 0 ]]; then
        info "Nothing to clean."
        return 0
    fi

    # Show what will happen
    info "Will REMOVE (plugins, skills, agents, config, etc.):"
    for item in "${to_remove[@]}"; do
        local size
        size=$(du -sh "$CLAUDE_DIR/$item" 2>/dev/null | cut -f1)
        printf "  ${RED}✗${RESET} %-40s %s\n" "$item" "$size"
    done

    echo ""
    info "Will PRESERVE (session history, runtime, credentials, mcp):"
    for item in "${preserve[@]}"; do
        if [[ -e "$CLAUDE_DIR/$item" ]]; then
            printf "  ${GREEN}✓${RESET} %s\n" "$item"
        fi
    done

    if [[ "$DRY_RUN" == true ]]; then
        echo ""
        info "[dry-run] No changes made."
        return 0
    fi

    # Confirm unless --force
    if [[ "$FORCE" != true ]]; then
        echo ""
        printf "Proceed? [y/N] "
        local reply
        read -r reply
        case "$reply" in
            [yY]|[yY][eE][sS]) ;;
            *) die "Aborted." ;;
        esac
    fi

    # Remove
    local count=0
    for item in "${to_remove[@]}"; do
        rm -rf "$CLAUDE_DIR/$item"
        debug "Removed: $item"
        (( count++ )) || true
    done

    # Remove any preserved dirs that are now empty
    for item in "${preserve[@]}"; do
        local path="$CLAUDE_DIR/$item"
        if [[ -d "$path" ]] && [[ -z "$(ls -A "$path" 2>/dev/null)" ]]; then
            rmdir "$path"
            debug "Removed empty preserved dir: $item"
        fi
    done

    info "Cleaned ${count} item(s). Session history and credentials preserved."
}

# --- list command ---
cmd_list() {
    if [[ ! -d "$BACKUP_DIR" ]]; then
        echo "No backups found."
        return 0
    fi

    local -a entries=()
    local dir
    for dir in "$BACKUP_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local manifest="$dir/manifest.json"
        [[ -f "$manifest" ]] || continue

        local name
        name="$(basename "$dir")"

        local created
        created=$(grep '"created"' "$manifest" | sed 's/.*"created": *"//;s/".*//')
        local created_display="${created:0:10} ${created:11:5}"

        # Count items (works with both v1 and v2 manifests)
        local item_count
        if grep -q '"backed_up"' "$manifest"; then
            # v2: count backed_up array entries
            item_count=$(grep -o '"[^"]*"' "$manifest" | wc -l)
        elif grep -q '"layers"' "$manifest"; then
            # v1: show layer names
            item_count=$(grep '"layers"' "$manifest" | sed 's/.*\[//;s/\].*//;s/"//g;s/ //g')
        else
            item_count="?"
        fi

        local size
        size=$(du -sh "$dir" 2>/dev/null | cut -f1)

        entries+=("${created}|${name}|${created_display}|${size}")
    done

    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No backups found."
        return 0
    fi

    local -a sorted=()
    mapfile -t sorted < <(printf '%s\n' "${entries[@]}" | sort -r)

    printf "%-34s%-22s%s\n" "Name" "Created" "Size"
    printf '%0.s─' {1..64}
    printf '\n'

    local entry
    for entry in "${sorted[@]}"; do
        local name created_display size
        IFS='|' read -r _ name created_display size <<< "$entry"
        printf "%-34s%-22s%s\n" "$name" "$created_display" "$size"
    done

    printf '\n%d backup(s) found.\n' "${#sorted[@]}"
}

# --- diff command ---
cmd_diff() {
    local name=""

    while [[ $# -gt 0 ]]; do
        case "$1" in
            -*)
                die "Unknown flag: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    [[ -n "$name" ]] || die "Backup name required. Usage: claude-env diff <name>"

    local backup_path="$BACKUP_DIR/$name"
    [[ -d "$backup_path" ]] || die "Backup '$name' not found at $backup_path"
    [[ -f "$backup_path/manifest.json" ]] || die "Invalid backup: manifest.json not found in $backup_path"

    local count_identical=0
    local count_modified=0
    local count_backup_only=0
    local count_current_only=0

    # Collect all items from both backup and current
    local -a all_items=()
    local item

    # Items in backup (excluding manifest)
    for item in "$backup_path"/* "$backup_path"/.*; do
        [[ -e "$item" ]] || continue
        local bname
        bname="$(basename "$item")"
        [[ "$bname" == "." || "$bname" == ".." || "$bname" == "manifest.json" ]] && continue
        if ! _array_contains "$bname" "${all_items[@]+"${all_items[@]}"}"; then
            all_items+=("$bname")
        fi
    done

    # Items in current
    for item in "$CLAUDE_DIR"/* "$CLAUDE_DIR"/.*; do
        [[ -e "$item" ]] || continue
        local bname
        bname="$(basename "$item")"
        [[ "$bname" == "." || "$bname" == ".." ]] && continue
        if ! _array_contains "$bname" "${all_items[@]+"${all_items[@]}"}"; then
            all_items+=("$bname")
        fi
    done

    # Sort for consistent output
    local -a sorted_items=()
    mapfile -t sorted_items < <(printf '%s\n' "${all_items[@]}" | sort)

    for item in "${sorted_items[@]}"; do
        local backup_src="$backup_path/$item"
        local current_src="$CLAUDE_DIR/$item"
        local in_backup=false
        local in_current=false

        [[ -e "$backup_src" ]] && in_backup=true
        [[ -e "$current_src" ]] && in_current=true

        local display="$item"
        if [[ -d "$backup_src" ]] || [[ -d "$current_src" ]]; then
            display="${item%/}/"
        fi

        if [[ "$in_backup" == true ]] && [[ "$in_current" == true ]]; then
            local diff_output
            if [[ -d "$backup_src" ]] && [[ -d "$current_src" ]]; then
                diff_output=$(diff -rq "$backup_src" "$current_src" 2>/dev/null || true)
                if [[ -z "$diff_output" ]]; then
                    printf "  ${GREEN}✓${RESET} %-40s — identical\n" "$display"
                    (( count_identical++ )) || true
                else
                    local diff_count
                    diff_count=$(printf '%s\n' "$diff_output" | wc -l)
                    printf "  ${YELLOW}~${RESET} %-40s — %d file(s) differ\n" "$display" "$diff_count"
                    (( count_modified++ )) || true
                fi
            elif [[ -f "$backup_src" ]] && [[ -f "$current_src" ]]; then
                if diff -q "$backup_src" "$current_src" >/dev/null 2>&1; then
                    printf "  ${GREEN}✓${RESET} %-40s — identical\n" "$display"
                    (( count_identical++ )) || true
                else
                    printf "  ${YELLOW}~${RESET} %-40s — modified\n" "$display"
                    (( count_modified++ )) || true
                fi
            else
                printf "  ${YELLOW}~${RESET} %-40s — modified (type changed)\n" "$display"
                (( count_modified++ )) || true
            fi
        elif [[ "$in_backup" == true ]] && [[ "$in_current" == false ]]; then
            printf "  ${RED}+${RESET} %-40s — only in backup\n" "$display"
            (( count_backup_only++ )) || true
        elif [[ "$in_backup" == false ]] && [[ "$in_current" == true ]]; then
            printf "  ${RED}-${RESET} %-40s — only in current\n" "$display"
            (( count_current_only++ )) || true
        fi
    done

    printf "\nSummary: %d identical, %d modified, %d only in backup, %d only in current\n" \
        "$count_identical" "$count_modified" "$count_backup_only" "$count_current_only"
}

# --- Global flag parsing ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dir)
            [[ $# -lt 2 ]] && die "--dir requires a value"
            BACKUP_DIR="$2"
            shift 2
            ;;
        --claude-dir)
            [[ $# -lt 2 ]] && die "--claude-dir requires a value"
            CLAUDE_DIR="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version|-v)
            echo "claude-env $VERSION"
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

# --- Subcommand dispatch ---
case "${1:-}" in
    backup)  shift; cmd_backup "$@" ;;
    restore) shift; cmd_restore "$@" ;;
    clean)   shift; cmd_clean "$@" ;;
    list)    shift; cmd_list "$@" ;;
    diff)    shift; cmd_diff "$@" ;;
    help)    usage ;;
    version) echo "claude-env $VERSION" ;;
    "")      usage ;;
    *)       die "Unknown command: $1. Run 'claude-env help' for usage." ;;
esac
