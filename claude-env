#!/usr/bin/env bash
set -euo pipefail

VERSION="0.1.0"

# --- Default variables ---
CLAUDE_DIR="${CLAUDE_DIR:-$HOME/.claude}"
BACKUP_DIR="${BACKUP_DIR:-$HOME/.claude-backups}"
DRY_RUN=false
VERBOSE=false
FORCE=false

# --- Color auto-detection ---
if [[ -t 1 ]] && [[ -z "${NO_COLOR:-}" ]]; then
    RED='\033[0;31m'
    BLUE='\033[0;34m'
    YELLOW='\033[0;33m'
    RESET='\033[0m'
else
    RED=''
    BLUE=''
    YELLOW=''
    RESET=''
fi

# --- Logging helpers ---
die() {
    printf "${RED}error:${RESET} %s\n" "$*" >&2
    exit 1
}

info() {
    printf "${BLUE}info:${RESET} %s\n" "$*"
}

warn() {
    printf "${YELLOW}warn:${RESET} %s\n" "$*" >&2
}

debug() {
    if [[ "$VERBOSE" == true ]]; then
        printf "debug: %s\n" "$*" >&2
    fi
}

# --- Layer definitions (paths relative to CLAUDE_DIR) ---
LAYER_CUSTOMIZATIONS=(
    "rules"
    "skills"
    "commands"
    "agents"
    "hooks"
    "CLAUDE.md"
)

LAYER_CONFIG=(
    "settings.json"
    "settings.local.json"
    "settings.json.bak"
    "statusline.sh"
    "statusline-command.sh"
    ".sisyphus-config.json"
    ".sisyphus-version.json"
    ".pilot-manifest.json"
    ".pilot-claude-baseline.json"
    ".pilot-settings-baseline.json"
)

LAYER_PLUGINS=(
    "plugins/installed_plugins.json"
    "plugins/config.json"
    "plugins/known_marketplaces.json"
    "plugins/local"
    "plugins/data"
)

LAYER_INTEGRATIONS=()

LAYER_CREDENTIALS=(
    ".credentials.json"
)

LAYER_MCP=(
    "mcp-servers"
    ".mcp.json"
)

# All layer names
ALL_LAYERS=(customizations config plugins integrations credentials mcp)

# Default behavior
DEFAULT_BACKUP_LAYERS=(customizations config plugins integrations)
DEFAULT_KEEP_LAYERS=(credentials mcp)

# --- Layer flag variables ---
INCLUDE_MCP=false
INCLUDE_CREDENTIALS=false
KEEP_CONFIG=false
KEEP_PLUGINS=false
NO_RESET=false
ONLY_LAYERS=""

# --- Layer helper functions ---
get_layer_paths() {
    local layer="$1"
    local -n arr="LAYER_${layer^^}"
    [[ ${#arr[@]} -eq 0 ]] && return 0
    printf '%s\n' "${arr[@]}"
}

# Check if an element is in an array
_array_contains() {
    local needle="$1"; shift
    local item
    for item in "$@"; do
        [[ "$item" == "$needle" ]] && return 0
    done
    return 1
}

# Remove an element from an array (prints remaining elements)
_array_remove() {
    local needle="$1"; shift
    local item
    for item in "$@"; do
        [[ "$item" != "$needle" ]] && printf '%s\n' "$item"
    done
}

resolve_layers() {
    local -a backup=("${DEFAULT_BACKUP_LAYERS[@]}")
    local -a keep=("${DEFAULT_KEEP_LAYERS[@]}")

    # --only overrides defaults entirely
    if [[ -n "$ONLY_LAYERS" ]]; then
        local -a only_arr=()
        IFS=',' read -ra only_arr <<< "$ONLY_LAYERS"
        backup=("${only_arr[@]}")
        keep=()
        local layer
        for layer in "${ALL_LAYERS[@]}"; do
            if ! _array_contains "$layer" "${backup[@]}"; then
                keep+=("$layer")
            fi
        done
    fi

    # --include-mcp: move mcp from keep to backup
    if [[ "$INCLUDE_MCP" == true ]]; then
        if _array_contains "mcp" "${keep[@]}"; then
            mapfile -t keep < <(_array_remove "mcp" "${keep[@]}")
            backup+=("mcp")
        fi
    fi

    # --include-credentials: move credentials from keep to backup
    if [[ "$INCLUDE_CREDENTIALS" == true ]]; then
        if _array_contains "credentials" "${keep[@]}"; then
            mapfile -t keep < <(_array_remove "credentials" "${keep[@]}")
            backup+=("credentials")
        fi
    fi

    # --keep-config: move config from backup to keep
    if [[ "$KEEP_CONFIG" == true ]]; then
        if _array_contains "config" "${backup[@]}"; then
            mapfile -t backup < <(_array_remove "config" "${backup[@]}")
            keep+=("config")
        fi
    fi

    # --keep-plugins: move plugins from backup to keep
    if [[ "$KEEP_PLUGINS" == true ]]; then
        if _array_contains "plugins" "${backup[@]}"; then
            mapfile -t backup < <(_array_remove "plugins" "${backup[@]}")
            keep+=("plugins")
        fi
    fi

    RESOLVED_BACKUP=("${backup[@]}")
    RESOLVED_KEEP=("${keep[@]}")
}

# --- debug-layers command ---
cmd_debug_layers() {
    # Parse layer-related flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --include-mcp)       INCLUDE_MCP=true; shift ;;
            --include-credentials) INCLUDE_CREDENTIALS=true; shift ;;
            --keep-config)       KEEP_CONFIG=true; shift ;;
            --keep-plugins)      KEEP_PLUGINS=true; shift ;;
            --no-reset)          NO_RESET=true; shift ;;
            --only)
                [[ $# -lt 2 ]] && die "--only requires a value"
                ONLY_LAYERS="$2"; shift 2
                ;;
            *) die "Unknown flag: $1" ;;
        esac
    done

    resolve_layers

    echo "Backup layers: ${RESOLVED_BACKUP[*]}"
    echo "Keep layers:   ${RESOLVED_KEEP[*]}"
}

# --- Usage ---
usage() {
    cat <<'EOF'
claude-env — snapshot, restore, and manage Claude Code environments

USAGE
    claude-env <command> [options]

COMMANDS
    backup [name]       Create a named snapshot of the current Claude environment
    restore <name>      Restore a previously saved snapshot
    list                List all available snapshots
    diff <name>         Show differences between current environment and a snapshot
    help                Show this help message
    version             Show version

GLOBAL FLAGS
    --dir <path>        Set backup directory (default: ~/.claude-backups)
    --claude-dir <path> Set Claude config directory (default: ~/.claude)
    --dry-run           Show what would be done without making changes
    --verbose           Enable verbose/debug output
    --help, -h          Show this help message
    --version, -v       Show version

BACKUP FLAGS
    --no-reset          Skip resetting the environment after backup
    --include-mcp       Include MCP server configurations
    --include-credentials
                        Include credential files in the backup
    --keep-config       Preserve configuration files during reset
    --keep-plugins      Preserve plugins during reset
    --only <layers>     Only backup specific layers (comma-separated)

RESTORE FLAGS
    --force             Overwrite current environment without confirmation

EXAMPLES
    claude-env backup                   # Backup with auto-generated name
    claude-env backup my-setup          # Backup with custom name
    claude-env restore my-setup         # Restore a snapshot
    claude-env list                     # List all snapshots
    claude-env diff my-setup            # Compare current env with snapshot
EOF
}

# --- JSON helper ---
# Build a JSON array from bash arguments (no jq dependency)
_json_array() {
    local first=true
    printf '['
    for item in "$@"; do
        if [[ "$first" == true ]]; then
            first=false
        else
            printf ','
        fi
        printf '"%s"' "$item"
    done
    printf ']'
}

# --- backup command ---
cmd_backup() {
    local name=""

    # Parse backup-specific flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --no-reset)              NO_RESET=true; shift ;;
            --force)                 FORCE=true; shift ;;
            --include-mcp)           INCLUDE_MCP=true; shift ;;
            --include-credentials)   INCLUDE_CREDENTIALS=true; shift ;;
            --keep-config)           KEEP_CONFIG=true; shift ;;
            --keep-plugins)          KEEP_PLUGINS=true; shift ;;
            --only)
                [[ $# -lt 2 ]] && die "--only requires a value"
                ONLY_LAYERS="$2"; shift 2
                ;;
            -*)
                die "Unknown flag: $1"
                ;;
            *)
                # First positional arg = backup name
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Determine backup name: positional arg or timestamp fallback
    if [[ -z "$name" ]]; then
        name="$(date -u +%Y-%m-%dT%H-%M-%S)"
    fi

    # Validate: CLAUDE_DIR exists
    [[ -d "$CLAUDE_DIR" ]] || die "Claude directory does not exist: $CLAUDE_DIR"

    # Validate: backup path doesn't already exist
    local backup_path="$BACKUP_DIR/$name"
    if [[ -d "$backup_path" ]] && [[ "$FORCE" != true ]]; then
        die "Backup '$name' already exists at $backup_path. Use a different name or --force."
    fi

    # Resolve which layers to backup/keep
    resolve_layers

    debug "Backup layers: ${RESOLVED_BACKUP[*]}"
    debug "Keep layers: ${RESOLVED_KEEP[*]}"

    # --- Copy phase ---
    local -a copied_layers=()
    local -a copied_paths=()

    for layer in "${RESOLVED_BACKUP[@]}"; do
        local layer_copied=false
        while IFS= read -r path; do
            # Skip empty paths (from layers with no entries)
            [[ -z "$path" ]] && continue
            local src="$CLAUDE_DIR/$path"
            if [[ -e "$src" ]]; then
                local dest="$backup_path/$path"
                if [[ "$DRY_RUN" == true ]]; then
                    info "[dry-run] Would copy: $path"
                else
                    # Create parent directory for the destination
                    mkdir -p "$(dirname "$dest")"
                    cp -a "$src" "$dest"
                    debug "Copied: $path"
                fi
                copied_paths+=("$path")
                layer_copied=true
            else
                debug "Skipped (not found): $path"
            fi
        done < <(get_layer_paths "$layer")

        if [[ "$layer_copied" == true ]]; then
            copied_layers+=("$layer")
        fi
    done

    # --- Write manifest.json ---
    local created
    created="$(date -u +%Y-%m-%dT%H:%M:%SZ)"
    local backup_json
    backup_json="$(_json_array "${copied_layers[@]}")"
    local kept_json
    kept_json="$(_json_array "${RESOLVED_KEEP[@]}")"

    local manifest
    manifest=$(printf '{\n  "version": 1,\n  "created": "%s",\n  "name": "%s",\n  "layers": %s,\n  "kept": %s,\n  "claude_dir": "%s"\n}' \
        "$created" "$name" "$backup_json" "$kept_json" "$CLAUDE_DIR")

    if [[ "$DRY_RUN" == true ]]; then
        info "[dry-run] Would write manifest.json:"
        printf '%s\n' "$manifest"
    else
        mkdir -p "$backup_path"
        printf '%s\n' "$manifest" > "$backup_path/manifest.json"
    fi

    # --- Reset phase ---
    local -a reset_paths=()

    if [[ "$NO_RESET" == true ]]; then
        debug "Skipping reset phase (--no-reset)"
    else
        for layer in "${RESOLVED_BACKUP[@]}"; do
            while IFS= read -r path; do
                [[ -z "$path" ]] && continue
                local target="$CLAUDE_DIR/$path"
                if [[ -e "$target" ]]; then
                    if [[ "$DRY_RUN" == true ]]; then
                        info "[dry-run] Would remove: $path"
                    else
                        rm -rf "$target"
                        debug "Removed: $path"
                    fi
                    reset_paths+=("$path")
                fi
            done < <(get_layer_paths "$layer")
        done
    fi

    # --- Summary ---
    if [[ "$DRY_RUN" == true ]]; then
        info "[dry-run] Backup '$name' would include layers: ${copied_layers[*]:-none}"
        info "[dry-run] Kept layers (not backed up): ${RESOLVED_KEEP[*]:-none}"
        if [[ "$NO_RESET" == true ]]; then
            info "[dry-run] Reset: skipped (--no-reset)"
        elif [[ ${#reset_paths[@]} -gt 0 ]]; then
            info "[dry-run] Would reset ${#reset_paths[@]} path(s)"
        else
            info "[dry-run] Nothing to reset"
        fi
    else
        local size
        size="$(du -sh "$backup_path" 2>/dev/null | cut -f1)"
        info "Backup created: $backup_path"
        info "Layers backed up: ${copied_layers[*]:-none}"
        info "Layers kept (not backed up): ${RESOLVED_KEEP[*]:-none}"
        if [[ "$NO_RESET" == true ]]; then
            info "Reset: skipped (--no-reset)"
        elif [[ ${#reset_paths[@]} -gt 0 ]]; then
            info "Reset ${#reset_paths[@]} path(s) from CLAUDE_DIR"
        else
            info "Nothing to reset"
        fi
        info "Total size: $size"
    fi
}

cmd_restore() {
    local name=""

    # Parse restore-specific flags
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --force)
                FORCE=true; shift ;;
            -*)
                die "Unknown flag: $1" ;;
            *)
                if [[ -z "$name" ]]; then
                    name="$1"
                else
                    die "Unexpected argument: $1"
                fi
                shift
                ;;
        esac
    done

    # Require backup name
    [[ -n "$name" ]] || die "Backup name required. Usage: claude-env restore <name>"

    # Validate backup exists
    local backup_path="$BACKUP_DIR/$name"
    [[ -d "$backup_path" ]] || die "Backup '$name' not found at $backup_path"
    [[ -f "$backup_path/manifest.json" ]] || die "Invalid backup: manifest.json not found in $backup_path"

    # Read manifest to get layers list
    local layers_str
    layers_str=$(grep '"layers"' "$backup_path/manifest.json" | sed 's/.*\[//;s/\].*//;s/"//g')
    local -a restore_layers
    IFS=',' read -ra restore_layers <<< "$layers_str"

    debug "Restore layers from manifest: ${restore_layers[*]}"

    # --- Dry-run mode ---
    if [[ "$DRY_RUN" == true ]]; then
        info "[dry-run] Would restore backup '$name' from $backup_path"
        info "[dry-run] Layers: ${restore_layers[*]}"
        for layer in "${restore_layers[@]}"; do
            while IFS= read -r path; do
                [[ -z "$path" ]] && continue
                if [[ -e "$backup_path/$path" ]]; then
                    info "[dry-run] Would restore: $path"
                fi
            done < <(get_layer_paths "$layer")
        done
        return 0
    fi

    # --- Auto-backup current state (unless --force) ---
    if [[ "$FORCE" != true ]]; then
        local auto_name="pre-restore-$(date -u +%Y-%m-%dT%H-%M-%S)"
        info "Auto-backing up current state as '$auto_name'..."

        # Reset layer flags so the auto-backup uses defaults
        INCLUDE_MCP=false
        INCLUDE_CREDENTIALS=false
        KEEP_CONFIG=false
        KEEP_PLUGINS=false
        NO_RESET=true  # Don't reset during auto-backup
        ONLY_LAYERS=""
        FORCE=false

        cmd_backup "$auto_name" --no-reset
    fi

    # --- Restore phase ---
    local -a restored_paths=()
    local -a restored_layers=()

    for layer in "${restore_layers[@]}"; do
        local layer_restored=false
        while IFS= read -r path; do
            [[ -z "$path" ]] && continue
            local src="$backup_path/$path"
            if [[ -e "$src" ]]; then
                local dest="$CLAUDE_DIR/$path"
                mkdir -p "$(dirname "$dest")"
                cp -a "$src" "$dest"
                debug "Restored: $path"
                restored_paths+=("$path")
                layer_restored=true
            else
                debug "Skipped (not in backup): $path"
            fi
        done < <(get_layer_paths "$layer")

        if [[ "$layer_restored" == true ]]; then
            restored_layers+=("$layer")
        fi
    done

    # --- Summary ---
    info "Restored backup '$name' from $backup_path"
    info "Layers restored: ${restored_layers[*]:-none}"
    info "Paths restored: ${#restored_paths[@]}"
}

cmd_list() {
    # Check if backup directory exists
    if [[ ! -d "$BACKUP_DIR" ]]; then
        echo "No backups found."
        return 0
    fi

    # Collect backups with manifest.json
    local -a entries=()
    local dir
    for dir in "$BACKUP_DIR"/*/; do
        [[ -d "$dir" ]] || continue
        local manifest="$dir/manifest.json"
        [[ -f "$manifest" ]] || continue

        local name
        name="$(basename "$dir")"

        # Extract created date
        local created
        created=$(grep '"created"' "$manifest" | sed 's/.*"created": *"//;s/".*//')
        local created_display="${created:0:10} ${created:11:5}"

        # Extract layers
        local layers
        layers=$(grep '"layers"' "$manifest" | sed 's/.*\[//;s/\].*//;s/"//g;s/ //g')

        # Get total size
        local size
        size=$(du -sh "$dir" 2>/dev/null | cut -f1)

        # Store as a sortable entry (created timestamp first for sorting)
        entries+=("${created}|${name}|${created_display}|${layers}|${size}")
    done

    # Check if any backups found
    if [[ ${#entries[@]} -eq 0 ]]; then
        echo "No backups found."
        return 0
    fi

    # Sort by created date (newest first)
    local -a sorted=()
    mapfile -t sorted < <(printf '%s\n' "${entries[@]}" | sort -r)

    # Print header
    printf "%-34s%-22s%-34s%s\n" "Name" "Created" "Layers" "Size"
    printf '%0.s─' {1..98}
    printf '\n'

    # Print each entry
    local entry
    for entry in "${sorted[@]}"; do
        local name created_display layers size
        IFS='|' read -r _ name created_display layers size <<< "$entry"
        printf "%-34s%-22s%-34s%s\n" "$name" "$created_display" "$layers" "$size"
    done

    # Total count
    printf '\n%d backup(s) found.\n' "${#sorted[@]}"
}

cmd_diff() {
    info "Not implemented yet"
}

# --- Global flag parsing ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dir)
            [[ $# -lt 2 ]] && die "--dir requires a value"
            BACKUP_DIR="$2"
            shift 2
            ;;
        --claude-dir)
            [[ $# -lt 2 ]] && die "--claude-dir requires a value"
            CLAUDE_DIR="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version|-v)
            echo "claude-env $VERSION"
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

# --- Subcommand dispatch ---
case "${1:-}" in
    backup)  shift; cmd_backup "$@" ;;
    restore) shift; cmd_restore "$@" ;;
    list)    shift; cmd_list "$@" ;;
    diff)         shift; cmd_diff "$@" ;;
    debug-layers) shift; cmd_debug_layers "$@" ;;
    help)         usage ;;
    version) echo "claude-env $VERSION" ;;
    "")      usage ;;
    *)       die "Unknown command: $1. Run 'claude-env help' for usage." ;;
esac
