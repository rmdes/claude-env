# --- Global flag parsing ---
while [[ $# -gt 0 ]]; do
    case "$1" in
        --dir)
            [[ $# -lt 2 ]] && die "--dir requires a value"
            BACKUP_DIR="$2"
            shift 2
            ;;
        --claude-dir)
            [[ $# -lt 2 ]] && die "--claude-dir requires a value"
            CLAUDE_DIR="$2"
            shift 2
            ;;
        --dry-run)
            DRY_RUN=true
            shift
            ;;
        --verbose)
            VERBOSE=true
            shift
            ;;
        --help|-h)
            usage
            exit 0
            ;;
        --version|-v)
            echo "claude-env $VERSION"
            exit 0
            ;;
        *)
            break
            ;;
    esac
done

# --- Subcommand dispatch ---
case "${1:-}" in
    backup)  shift; cmd_backup "$@" ;;
    restore) shift; cmd_restore "$@" ;;
    list)    shift; cmd_list "$@" ;;
    diff)         shift; cmd_diff "$@" ;;
    debug-layers) shift; cmd_debug_layers "$@" ;;
    help)         usage ;;
    version) echo "claude-env $VERSION" ;;
    "")      usage ;;
    *)       die "Unknown command: $1. Run 'claude-env help' for usage." ;;
esac
